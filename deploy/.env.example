# doclingllm — переменные деплоя (скопировать в deploy/.env, НЕ коммитить)
# cp deploy/.env.example deploy/.env

# --- Vision / OCR (Cloud.ru Foundation Models) ---
VISION_API_BASE_URL=https://foundation-models.api.cloud.ru/v1
VISION_API_KEY=replace-with-your-cloud-ru-token
VISION_MODEL=deepseek-ai/DeepSeek-OCR-2

# --- Text (локальная LAN, OpenAI-compatible) ---
TEXT_API_BASE_URL=http://192.168.101.15:8111/v1
TEXT_API_KEY=
TEXT_MODEL=minimax-m2.7

# --- Model Gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_REQUEST_TIMEOUT=120

# --- docling-serve (передаётся через docker-compose) ---
DOCLING_SERVE_ENABLE_REMOTE_SERVICES=true
DOCLING_SERVE_LOAD_MODELS_AT_BOOT=false
DOCLING_SERVE_LOG_FORMAT=json
DOCLING_DEVICE=cpu
UVICORN_PORT=5001

# Docker: docling-serve должен достучаться до LAN-хоста с minimax.
# На Linux при необходимости раскомментировать в docker-compose.yml:
# extra_hosts: ["host.docker.internal:host-gateway"]
