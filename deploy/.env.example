# doclingllm — шаблон deploy/.env (legacy; предпочтительно deploy/.env.defaults + ./scripts/start.sh)
# cp deploy/.env.defaults deploy/.env   # или просто ./scripts/start.sh — создаст .env и запросит токен

# --- Vision / VLM (Develonica OpenAI-compatible) ---
VISION_API_BASE_URL=https://ai-billing.develonica.group/v1
VISION_API_KEY=
VISION_MODEL=qwen3.6-35b-a3b

# --- Text (локальная LAN, OpenAI-compatible) ---
TEXT_API_BASE_URL=http://192.168.101.15:8111/v1
TEXT_API_KEY=
TEXT_MODEL=minimax-m2.7

# --- Model Gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_REQUEST_TIMEOUT=300
GATEWAY_UPSTREAM_RETRIES=1
GATEWAY_LOG_LEVEL=INFO

# --- Optional egress proxy (httpx trust_env=True) ---
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1,model-gateway,docling-serve

# --- docling-serve (передаётся через docker-compose) ---
DOCLING_SERVE_ENABLE_REMOTE_SERVICES=true
DOCLING_SERVE_ENABLE_UI=true
DOCLING_SERVE_LOAD_MODELS_AT_BOOT=false
DOCLING_SERVE_LOG_FORMAT=json
DOCLING_DEVICE=cpu
UVICORN_PORT=5001
